# Скопируйте в .env.local при необходимости.
# Локально SQLite — не задавайте DATABASE_URL или укажите путь:
# DATABASE_URL=./data/app.db

# Продакшен / превью Vercel (Supabase)
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# GitHub Actions secrets: DATABASE_URL, VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
# Опционально RUN_SEED=true — засеять демо-данные на Supabase после миграции
