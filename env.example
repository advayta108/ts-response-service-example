# Локально SQLite — не задавайте postgres-URL:
# DATABASE_URL=./data/app.db
# (или вообще без DATABASE_URL)

# --- Vercel + Supabase (интеграция сама создаёт POSTGRES_* — дублировать DATABASE_URL не обязательно)
# Приложение и миграции берут URL в порядке: DATABASE_URL → POSTGRES_URL_NON_POOLING → POSTGRES_URL → POSTGRES_PRISMA_URL

# POSTGRES_URL_NON_POOLING=postgres://...@...pooler...:5432/postgres?sslmode=require
# POSTGRES_URL=postgres://...@...pooler...:6543/...
# SUPABASE_URL=   NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=   NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub Actions (любой один секрет с postgres://):
#   DATABASE_URL  или  POSTGRES_URL_NON_POOLING  или  POSTGRES_URL
# Плюс: VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
# Опционально RUN_SEED=true
